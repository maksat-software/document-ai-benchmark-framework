# ==========================================
# Azure Document Intelligence
# ==========================================
AZURE_DI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DI_KEY=your-azure-di-key
AZURE_DI_MODEL_ID=prebuilt-invoice
AZURE_DI_API_VERSION=2024-11-30

# ==========================================
# LLM Extraction (OpenAI or compatible: vLLM, Ollama, Groq)
# ==========================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=https://api.openai.com/v1
OPENAI_BASE_URL=gpt-5.4

# ==========================================
# Anthropic
# ==========================================
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6
